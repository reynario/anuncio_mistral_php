{
  "name": "reynario/anuncios-meta-mistral-php",
  "description": "Criacao de campanhas Meta Ads via API - versao PHP",
  "type": "project",
  "require": {
    "php": "^8.3",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "php-di/slim-bridge": "^3.4",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9",
    "google/auth": "^1.34",
    "monolog/monolog": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
