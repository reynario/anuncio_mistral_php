PORT=8787

# Auth opcional para proteger endpoints.
APP_API_KEY=

# Meta Graph API
META_API_URL=https://graph.facebook.com/v25.0
META_ACCESS_TOKEN=
DEFAULT_DESTINATION_URL=https://example.com

# Google Drive (preview + download de criativos)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/google/oauth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=

# Dropbox (alternativa ao Drive para criativos)
# Opção 1 — token estático (expira em ~4h, não recomendado para produção):
DROPBOX_ACCESS_TOKEN=

# Opção 2 — refresh token (recomendado, não expira):
# 1. Crie um app em https://www.dropbox.com/developers/apps
# 2. Em "OAuth 2", defina o Redirect URI abaixo e salve
# 3. Acesse GET /api/dropbox/oauth/start para iniciar o fluxo
# 4. Copie o refresh_token retornado e coloque em DROPBOX_REFRESH_TOKEN
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_OAUTH_REDIRECT_URI=http://localhost:8787/api/dropbox/oauth/callback
DROPBOX_REFRESH_TOKEN=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=meta_ads
